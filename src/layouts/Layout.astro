---
import VisualEditing from '../components/VisualEditing'
import { sanityClient, QUERY_CONFIG, telUrl, whatsappUrl, formatPhoneES } from '../lib/sanityClient'

export interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const {
  title,
  description = 'Muebles Fran Barcelona — Tienda de muebles y decoración en Gran Vía 1105. Salones, dormitorios, cocinas, baños y juvenil.',
  ogImage = '/img/Logo-muebles-barcelona.jpg',
} = Astro.props;

const config = await sanityClient.fetch(QUERY_CONFIG).catch(() => null);
const telefono     = config?.telefono  ?? '93 313 88 06';
const whatsapp     = config?.whatsapp  ?? '644 48 45 63';
const email        = config?.email     ?? 'comercial@mfran.com';
const direccion    = config?.direccion ?? 'Gran Vía de les Corts Catalanes 1105, 08020 Barcelona';
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <title>{title}</title>
  <link rel="stylesheet" href="/style.css" />
  <link rel="stylesheet" href="/additions.css" />
  <link rel="icon" type="image/jpeg" href="/img/Logo-muebles-barcelona.jpg" />
</head>
<body>

  <!-- ===== HEADER / NAV ===== -->
  <header class="header-v2">
    <nav>
      <a href="/" class="logo-wrap" aria-label="Muebles Fran — Inicio">
        <img class="logo-img" src="/img/Logo-muebles-barcelona.jpg" alt="Muebles Fran · Mobiliari Interiorisme" />
      </a>
      <ul class="nav-links">
        <li><a href="/nosotros">Nosotros</a></li>
        <li>
          <a href="#">Muebles <svg class="nav-arrow" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.5"><polyline points="2,3 5,7 8,3"/></svg></a>
          <div class="nav-dropdown">
            <a href="/salones">Salones</a>
            <a href="/dormitorios">Dormitorios</a>
            <a href="/juvenil">Juvenil</a>
            <a href="/banos">Baños</a>
            <a href="/cocinas">Cocinas</a>
          </div>
        </li>
        <li><a href="/novedades">Blog</a></li>
        <li><a href="/#contacto">Contacto</a></li>
      </ul>
      <div class="hdr-cta">
        <a href={telUrl(telefono)} class="hdr-cta-tel" aria-label={`Llamar al ${telefono}`}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          <span class="call-label">{telefono}</span>
        </a>
        <a href="/#contacto" class="hdr-cta-directions">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          <span>Cómo llegar</span>
        </a>
        <button class="hamburger" id="hamburgerBtn" aria-label="Abrir menú" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>
    <div class="mobile-menu" id="mobileMenu">
      <a href="/">Inicio</a>
      <a href="/nosotros">Nosotros</a>
      <span class="mobile-section-title">Muebles</span>
      <a href="/salones" style="padding-left:36px;">— Salones</a>
      <a href="/dormitorios" style="padding-left:36px;">— Dormitorios</a>
      <a href="/juvenil" style="padding-left:36px;">— Juvenil</a>
      <a href="/banos" style="padding-left:36px;">— Baños</a>
      <a href="/cocinas" style="padding-left:36px;">— Cocinas</a>
      <a href="/novedades">Blog</a>
      <a href="/#contacto">Contacto</a>
      <div class="mobile-menu-ctas">
        <a href={telUrl(telefono)} class="mm-cta mm-cta-primary">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
          Llamar · {telefono}
        </a>
        <a href={whatsappUrl(whatsapp)} target="_blank" rel="noopener" class="mm-cta mm-cta-wa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4 0-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.3C8.6 21.5 10.3 22 12 22c5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
          WhatsApp
        </a>
        <a href="/#contacto" class="mm-cta mm-cta-ghost">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Cómo llegar
        </a>
      </div>
    </div>
  </header>

  <!-- ===== CONTENIDO DE LA PÁGINA ===== -->
  <slot />

  <!-- ===== FOOTER ===== -->
  <footer>
    <div class="container">
      <div class="footer-inner">
        <div>
          <img class="footer-logo-img" src="/img/Logo-muebles-barcelona.jpg" alt="Muebles Fran · Mobiliari Interiorisme" />
          <div class="footer-tagline">Mobiliari Interiorisme · Barcelona</div>
        </div>
        <div class="footer-links">
          <h4>Muebles</h4>
          <ul>
            <li><a href="/salones">Salones</a></li>
            <li><a href="/dormitorios">Dormitorios</a></li>
            <li><a href="/juvenil">Juvenil</a></li>
            <li><a href="/banos">Baños</a></li>
            <li><a href="/cocinas">Cocinas</a></li>
          </ul>
        </div>
        <div class="footer-links">
          <h4>Contacto</h4>
          <ul>
            <li><a href={telUrl(telefono)}>{telefono}</a></li>
            <li><a href={whatsappUrl(whatsapp)} target="_blank" rel="noopener">{formatPhoneES(whatsapp)} (WhatsApp)</a></li>
            <li><a href={`mailto:${email}`}>{email}</a></li>
            <li><span>{direccion}</span></li>
          </ul>
        </div>
      </div>
      <div class="footer-bottom">© 2026 Muebles Fran · Barcelona · Todos los derechos reservados</div>
    </div>
  </footer>

  <!-- ===== LIGHTBOX ===== -->
  <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="Visualizador de imágenes">
    <button id="lbClose" class="lb-close" aria-label="Cerrar">✕</button>
    <button id="lbPrev" class="lb-prev" aria-label="Anterior">‹</button>
    <button id="lbNext" class="lb-next" aria-label="Siguiente">›</button>
    <div id="lbLoading" class="lb-loading" style="display:none">Cargando…</div>
    <img id="lbImg" src="" alt="Imagen ampliada" class="lb-img" />
    <div id="lbCounter" class="lb-counter"></div>
  </div>

  <!-- ===== SCRIPTS ===== -->
  <script>
    // Header scrolled state (rediseño hero-v2)
    var hdr = document.querySelector('.header-v2');
    if (hdr) {
      var onScroll = function() {
        if (window.scrollY > 12) {
          hdr!.classList.add('scrolled');
        } else {
          hdr!.classList.remove('scrolled');
        }
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });
    }

    // Hamburger menu
    var hBtn = document.getElementById('hamburgerBtn');
    var mMenu = document.getElementById('mobileMenu');
    if (hBtn) {
      hBtn.addEventListener('click', function(e) {
        e.stopPropagation();
        var open = mMenu!.classList.toggle('open');
        hBtn!.setAttribute('aria-expanded', String(open));
      });
      mMenu!.querySelectorAll('a').forEach(function(l) {
        l.addEventListener('click', function() {
          mMenu!.classList.remove('open');
          hBtn!.setAttribute('aria-expanded', 'false');
        });
      });
      window.addEventListener('scroll', function() {
        mMenu!.classList.remove('open');
        hBtn!.setAttribute('aria-expanded', 'false');
      }, { passive: true });
    }

    // Lightbox
    (function() {
      var lb = document.getElementById('lightbox');
      var lbImg = document.getElementById('lbImg') as HTMLImageElement;
      var lbCounter = document.getElementById('lbCounter');
      var lbLoading = document.getElementById('lbLoading');
      var items = Array.from(document.querySelectorAll('.gallery-item'));
      var current = 0;

      function openLb(idx: number) {
        current = idx;
        var item = items[idx] as HTMLAnchorElement;
        var src = item.dataset.full || (item.querySelector('img') as HTMLImageElement)?.src || '';
        lbLoading!.style.display = 'block';
        lbImg!.style.opacity = '0';
        lb!.classList.add('open');
        document.body.style.overflow = 'hidden';
        lbCounter!.textContent = (idx + 1) + ' / ' + items.length;
        var tmp = new Image();
        tmp.onload = function() {
          lbImg!.src = src;
          lbImg!.style.opacity = '1';
          lbLoading!.style.display = 'none';
        };
        tmp.src = src;
      }

      function closeLb() {
        lb!.classList.remove('open');
        document.body.style.overflow = '';
        lbImg!.src = '';
      }

      function prev() { openLb((current - 1 + items.length) % items.length); }
      function next() { openLb((current + 1) % items.length); }

      items.forEach(function(item, i) {
        item.addEventListener('click', function(e) { e.preventDefault(); openLb(i); });
      });

      document.getElementById('lbClose')?.addEventListener('click', closeLb);
      document.getElementById('lbPrev')?.addEventListener('click', prev);
      document.getElementById('lbNext')?.addEventListener('click', next);
      lb?.addEventListener('click', function(e) { if (e.target === lb) closeLb(); });
      document.addEventListener('keydown', function(e) {
        if (!lb!.classList.contains('open')) return;
        if (e.key === 'Escape') closeLb();
        if (e.key === 'ArrowLeft') prev();
        if (e.key === 'ArrowRight') next();
      });
    })();
  </script>
  <script is:inline src="/wa-btn.js"></script>

  <VisualEditing client:only="react" />

</body>
</html>
