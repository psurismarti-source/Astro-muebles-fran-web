---
import Layout from '../../layouts/Layout.astro';
import { sanityClient, QUERY_NOTICIAS, ds } from '../../lib/sanityClient';

const noticias: any[] = await sanityClient.fetch(QUERY_NOTICIAS).catch(() => []);

function formatFecha(iso: string) {
  return new Date(iso).toLocaleDateString('es-ES', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}
---

<Layout
  title="Novedades | Muebles Fran Barcelona"
  description="Últimas noticias y novedades de Muebles Fran Barcelona. Tendencias en decoración, nuevas colecciones y consejos de interiorismo."
>

  <div class="page-hero">
    <div class="page-hero-inner">
      <span class="page-hero-tag">Blog</span>
      <h1>Novedades</h1>
    </div>
  </div>

  <section style="padding: 4rem 1.5rem;">
    <div class="container" style="max-width: 960px;">

      {noticias.length === 0 && (
        <div style="text-align:center; padding: 4rem 0; color: #888;">
          <p>Las novedades aparecerán aquí una vez hayas conectado Sanity y publicado el primer artículo.</p>
          <p style="margin-top:1rem; font-size:0.9rem;">
            Para publicar: entra en tu Sanity Studio → sección "Novedades" → crea una nueva entrada.
          </p>
        </div>
      )}

      <div class="blog-grid">
        {noticias.map((noticia: any) => (
          <a href={`/novedades/${noticia.slug}`} class="blog-card">
            {noticia.imagen?.asset?.url && (
              <div class="blog-card-img">
                <img
                  src={noticia.imagen.asset.url + '?w=600&auto=format'}
                  alt={noticia.titulo}
                  loading="lazy"
                  data-sanity={ds(noticia._id, 'noticia', 'imagen')}
                />
              </div>
            )}
            <div class="blog-card-body">
              <time class="blog-card-date" data-sanity={ds(noticia._id, 'noticia', 'fecha')}>{formatFecha(noticia.fecha)}</time>
              <h2 class="blog-card-title" data-sanity={ds(noticia._id, 'noticia', 'titulo')}>{noticia.titulo}</h2>
              {noticia.resumen && <p class="blog-card-excerpt" data-sanity={ds(noticia._id, 'noticia', 'resumen')}>{noticia.resumen}</p>}
              <span class="blog-card-cta">Leer más →</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

</Layout>
