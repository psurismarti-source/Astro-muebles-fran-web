---
import Layout from '../layouts/Layout.astro';
import { sanityClient, QUERY_PAGINA_INICIO, QUERY_NOTICIAS_RECIENTES, QUERY_CONFIG, ds } from '../lib/sanityClient';

const data   = await sanityClient.fetch(QUERY_PAGINA_INICIO).catch(() => null);
const config = await sanityClient.fetch(QUERY_CONFIG).catch(() => null);
const noticias: any[] = await sanityClient.fetch(QUERY_NOTICIAS_RECIENTES(3)).catch(() => []);

// Datos de empresa
const telefono  = config?.telefono  ?? '93 313 88 06';
const whatsapp  = config?.whatsapp  ?? '644 48 45 63';
const email     = config?.email     ?? 'comercial@mfran.com';
const direccion = config?.direccion ?? 'Gran Vía de les Corts Catalanes 1105, 08020 Barcelona';
const horario   = config?.horario   ?? 'Lun–Vie: 9:30–13:30 y 16:30–20:30 · Sáb: 10:00–14:00';

function formatFecha(iso: string) {
  return new Date(iso).toLocaleDateString('es-ES', { day: 'numeric', month: 'long', year: 'numeric' });
}

// Valores por defecto si Sanity no tiene contenido todavía
const heroBadge        = data?.heroBadge        ?? 'Barcelona · Desde 1998';
const heroTitulo       = data?.heroTitulo       ?? 'Muebles con carácter para tu hogar en Barcelona.';
const heroSubtitulo    = data?.heroSubtitulo    ?? 'Sofás, dormitorios, comedores y salones escogidos con criterio. Ven a tocar, probar y elegir — te asesoramos sin compromiso.';
const heroCtaLlamar    = data?.heroCtaLlamar    ?? 'Llamar ahora';
const heroCtaComoLlegar = data?.heroCtaComoLlegar ?? 'Cómo llegar';
const heroCtaWhatsapp  = data?.heroCtaWhatsapp  ?? 'WhatsApp';

const defaultMetaTags = [
  'Tienda física en Barcelona',
  'Más de 25 años sirviendo al barrio',
  'Atención personalizada',
];
const heroMetaTags = (data?.heroMetaTags && data.heroMetaTags.length > 0) ? data.heroMetaTags : defaultMetaTags;

const heroImagen = 'https://images.unsplash.com/photo-1586023492125-27b2c045efd7?w=2200&q=80&auto=format&fit=crop';

// Trust items (4 celdas bajo el hero): usa Sanity si existen, si no los valores por defecto
const defaultTrustItems = [
  { _key: 't1', numero: '01', titulo: 'Dirección', descripcion: direccion },
  { _key: 't2', numero: '02', titulo: 'Teléfono',  descripcion: 'Te atendemos personalmente, sin IVRs ni esperas.' },
  { _key: 't3', numero: '03', titulo: 'Horario',   descripcion: horario },
  { _key: 't4', numero: '04', titulo: 'Parking',   descripcion: 'Parking gratuito para clientes. Ven sin prisas.' },
];
const trustItems = (data?.trustItems && data.trustItems.length > 0) ? data.trustItems : defaultTrustItems;
const trustIcons = [
  // 01 — pin
  '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  // 02 — phone
  '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/>',
  // 03 — clock
  '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  // 04 — parking
  '<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 17V7h4a3 3 0 0 1 0 6H9"/>',
];
const productosTitulo    = data?.productosTitulo    ?? 'Nuestros productos';
const productosSubtitulo = data?.productosSubtitulo ?? 'Encuentra todo lo que necesitas para amueblar tu hogar';
const ventajasTitulo    = data?.ventajasTitulo    ?? 'Muebles Fran';
const ventajasSubtitulo = data?.ventajasSubtitulo ?? 'Calidad, servicio y experiencia a tu disposición';
const blogTitulo    = data?.blogTitulo    ?? 'Blog';
const blogSubtitulo = data?.blogSubtitulo ?? 'Consejos, tendencias e inspiración para tu hogar';
const parkingTitulo      = data?.parkingTitulo      ?? 'Parking gratuito para clientes';
const parkingDescripcion = data?.parkingDescripcion ?? 'Ven en coche sin preocuparte por el aparcamiento — disponemos de parking propio y gratuito para todos nuestros clientes.';
const parkingCta         = data?.parkingCta         ?? 'Ver ubicación →';
const contactoTitulo    = data?.contactoTitulo    ?? 'Visítanos en tienda';
const contactoSubtitulo = data?.contactoSubtitulo ?? 'Estamos en Barcelona, listos para atenderte. Ven a conocer nuestra exposición y encuentra el mueble perfecto para tu hogar.';
const docId = data?._id ?? 'pagina-inicio-singleton';

// Ventajas: usa Sanity si existen, si no los valores por defecto
const ventajas = data?.ventajas?.length > 0 ? data.ventajas : [
  { _key: 'v1', icono: '⭐', titulo: 'Calidad garantizada',    descripcion: 'Trabajamos con fabricantes de confianza para ofrecerte muebles duraderos.' },
  { _key: 'v2', icono: '👥', titulo: 'Atención personalizada', descripcion: 'Te asesoramos para encontrar la solución perfecta para tu espacio.' },
  { _key: 'v3', icono: '⏱️', titulo: 'Años de experiencia',    descripcion: 'Décadas ayudando a familias de Barcelona a amueblar sus hogares.' },
  { _key: 'v4', icono: '🚚', titulo: 'Entrega a domicilio',    descripcion: 'Llevamos tus muebles a casa y te ayudamos con el montaje.' },
];
---

<Layout
  title="Muebles Fran Barcelona — Tienda de muebles y decoración"
  description="Muebles Fran, tu tienda de muebles en Barcelona. Salones, dormitorios, cocinas, baños y juvenil. Gran Vía 1105, 08020 Barcelona."
>

  <!-- ===== HERO (rediseño v2) ===== -->
  <section id="hero" class="mf-hero">
    <div class="mf-hero-bg" style={`background-image:url('${heroImagen}')`}></div>
    <div class="container mf-hero-inner">
      <div class="mf-hero-grid">
        <div>
          <div class="mf-eyebrow" data-sanity={ds(docId, 'paginaInicio', 'heroBadge')}>{heroBadge}</div>
          <h1 class="mf-display" data-sanity={ds(docId, 'paginaInicio', 'heroTitulo')}>{heroTitulo}</h1>
        </div>
        <div class="mf-hero-right">
          <p class="mf-lead" data-sanity={ds(docId, 'paginaInicio', 'heroSubtitulo')}>{heroSubtitulo}</p>
          <div class="mf-hero-ctas">
            <a href={`tel:+34${telefono.replace(/\s/g,'')}`} class="mf-btn mf-btn-light">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6A19.79 19.79 0 0 1 2.12 4.18 2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              <span data-sanity={ds(docId, 'paginaInicio', 'heroCtaLlamar')}>{heroCtaLlamar}</span>
            </a>
            <a href="#contacto" class="mf-btn mf-btn-ghost">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span data-sanity={ds(docId, 'paginaInicio', 'heroCtaComoLlegar')}>{heroCtaComoLlegar}</span>
            </a>
            <a href={`https://wa.me/34${whatsapp.replace(/\s/g,'')}`} target="_blank" rel="noopener" class="mf-btn mf-btn-wa">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4c-.3-.1-1.7-.9-2-1-.3-.1-.5-.1-.7.1-.2.3-.8 1-1 1.2-.2.2-.4.2-.7.1-.3-.1-1.3-.5-2.4-1.5-.9-.8-1.5-1.8-1.7-2.1-.2-.3 0-.5.1-.6.1-.1.3-.4.4-.5.1-.2.2-.3.3-.5.1-.2 0-.4 0-.5-.1-.1-.7-1.7-1-2.3-.3-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.5s1.1 2.9 1.2 3.1c.1.2 2.1 3.3 5.2 4.6.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.4 0-.1-.3-.2-.6-.3zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.3 5L2 22l5.2-1.3C8.6 21.5 10.3 22 12 22c5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
              <span data-sanity={ds(docId, 'paginaInicio', 'heroCtaWhatsapp')}>{heroCtaWhatsapp}</span>
            </a>
          </div>
        </div>
      </div>
      <div class="mf-hero-meta">
        {heroMetaTags.map((tag: string) => (
          <span><span class="mf-hero-dot"></span>{tag}</span>
        ))}
      </div>
    </div>
    <div class="mf-hero-scroll"><span>Scroll</span></div>
  </section>

  <!-- ===== BLOQUE TRUST (4 celdas) ===== -->
  <section class="mf-trust-section">
    <div class="mf-trust">
      {trustItems.map((item: any, idx: number) => (
        <div class="mf-trust-cell" data-sanity={item._key ? ds(docId, 'paginaInicio', `trustItems[_key=="${item._key}"]`) : undefined}>
          <div class="mf-trust-num">{item.numero ?? String(idx + 1).padStart(2, '0')}</div>
          <div class="mf-trust-ico">
            <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={trustIcons[idx] ?? trustIcons[0]}></svg>
          </div>
          <h3>{item.titulo}</h3>
          <p>{item.descripcion}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== PRODUCTOS ===== -->
  <section id="productos">
    <div class="container">
      <div class="productos-header">
        <h2 class="section-title" data-sanity={ds(docId, 'paginaInicio', 'productosTitulo')}>{productosTitulo}</h2>
        <p class="section-subtitle" data-sanity={ds(docId, 'paginaInicio', 'productosSubtitulo')}>{productosSubtitulo}</p>
      </div>
      <div class="productos-grid">
        <a href="/salones" class="producto-card">
          <div class="producto-img"><img src="/img/gallery/salones-ambientes/sal-amb-1.jpg" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
          <div class="producto-info">
            <h3>Salones</h3>
            <p>Sofás, sillones, módulos de TV y todo lo necesario para crear tu salón perfecto.</p>
          </div>
        </a>

        <a href="/dormitorios" class="producto-card">
          <div class="producto-img"><img src="/img/gallery/dormitorios-ambientes/dor-amb-1.jpg" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
          <div class="producto-info">
            <h3>Dormitorios</h3>
            <p>Camas, armarios, mesitas y cabeceros para crear el dormitorio que imaginas.</p>
          </div>
        </a>

        <a href="/juvenil" class="producto-card">
          <div class="producto-img"><img src="/img/gallery/juvenil-ambientes/juv-amb-1.jpg" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
          <div class="producto-info">
            <h3>Juvenil</h3>
            <p>Habitaciones juveniles funcionales, con literas, escritorios y soluciones de almacenaje.</p>
          </div>
        </a>

        <a href="/banos" class="producto-card">
          <div class="producto-img"><img src="/img/gallery/banos/Bold_Tones_Hormigon_01-copy.jpg" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
          <div class="producto-info">
            <h3>Baños</h3>
            <p>Muebles de baño, espejos y accesorios para renovar tu espacio con estilo.</p>
          </div>
        </a>

        <a href="/cocinas" class="producto-card">
          <div class="producto-img"><img src="/img/gallery/cocinas/Copia-de-OB_COMPOSICION-1-1536x832.jpg" alt="" loading="lazy" style="width:100%;height:100%;object-fit:cover;display:block;" /></div>
          <div class="producto-info">
            <h3>Cocinas</h3>
            <p>Muebles de cocina a medida, encimeras y soluciones de almacenaje para cada espacio.</p>
          </div>
        </a>

        <div class="producto-card" style="background: var(--negro); color: white;">
          <div class="producto-img" style="background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.6); border-bottom: 1px solid rgba(255,255,255,0.1);">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" /><line x1="16" y1="2" x2="16" y2="6" /><line x1="8" y1="2" x2="8" y2="6" /><line x1="3" y1="10" x2="21" y2="10" /></svg>
            ¿No sabes por dónde empezar?
          </div>
          <div class="producto-info" style="background: transparent;">
            <h3 style="color: white;">Pide cita previa</h3>
            <p style="color: rgba(255,255,255,0.65);">Te atendemos de forma personalizada y sin esperas.</p>
            <a href="tel:+34933138806" class="btn-primary" style="background: white; color: #0a0a0a; margin-top: 12px; display: inline-block;">
              📞 Reservar cita
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== POR QUÉ ELEGIRNOS ===== -->
  <section id="ventajas">
    <div class="container">
      <div class="ventajas-header">
        <h2 class="section-title" data-sanity={ds(docId, 'paginaInicio', 'ventajasTitulo')}>{ventajasTitulo}</h2>
        <p class="section-subtitle" data-sanity={ds(docId, 'paginaInicio', 'ventajasSubtitulo')}>{ventajasSubtitulo}</p>
      </div>
      <div class="ventajas-grid">
        {ventajas.map((v: any) => (
          <div class="ventaja" data-sanity={ds(docId, 'paginaInicio', `ventajas[_key=="${v._key}"]`)}>
            <div class="ventaja-icon" style="font-size:1.5rem; display:flex; align-items:center; justify-content:center;">
              {v.icono}
            </div>
            <h3>{v.titulo}</h3>
            <p>{v.descripcion}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== PARKING BANNER ===== -->
  <div class="parking-banner">
    <div class="container">
      <div class="parking-banner-inner">
        <div class="parking-banner-icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" /><path d="M9 17V7h4a3 3 0 0 1 0 6H9" /></svg>
        </div>
        <div class="parking-banner-text">
          <strong data-sanity={ds(docId, 'paginaInicio', 'parkingTitulo')}>{parkingTitulo}</strong>
          <span data-sanity={ds(docId, 'paginaInicio', 'parkingDescripcion')}>{parkingDescripcion}</span>
        </div>
        <a href="#contacto" class="parking-banner-cta" data-sanity={ds(docId, 'paginaInicio', 'parkingCta')}>{parkingCta}</a>
      </div>
    </div>
  </div>

  <!-- ===== CONTACTO ===== -->
  <section id="contacto">
    <div class="container">
      <div class="contacto-inner">
        <div class="contacto-info">
          <h2 class="section-title" data-sanity={ds(docId, 'paginaInicio', 'contactoTitulo')}>{contactoTitulo}</h2>
          <p data-sanity={ds(docId, 'paginaInicio', 'contactoSubtitulo')}>{contactoSubtitulo}</p>

          <div class="contacto-dato">
            <div class="contacto-dato-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
            </div>
            <div class="contacto-dato-text">
              <strong>Dirección</strong>
              <a href={`https://maps.google.com/?q=${encodeURIComponent(direccion)}`} target="_blank" rel="noopener">
                {direccion}
              </a>
            </div>
          </div>

          <div class="contacto-dato">
            <div class="contacto-dato-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10" /><polyline points="12 6 12 12 16 14" /></svg>
            </div>
            <div class="contacto-dato-text">
              <strong>Horario</strong>
              <span>{horario}</span>
            </div>
          </div>

          <div class="contacto-dato">
            <div class="contacto-dato-icon">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" /><polyline points="22,6 12,13 2,6" /></svg>
            </div>
            <div class="contacto-dato-text">
              <strong>Email</strong>
              <a href={`mailto:${email}`}>{email}</a>
            </div>
          </div>

          <div class="contacto-ctas-grandes">
            <a href="https://maps.google.com/?q=Gran+Vía+de+les+Corts+Catalanes+1105+08020+Barcelona" target="_blank" rel="noopener" class="cta-grande cta-negro">
              <div class="cta-grande-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" /><circle cx="12" cy="10" r="3" /></svg>
              </div>
              <div class="cta-grande-text">
                <span class="cta-grande-label">Cómo llegar</span>
                <span class="cta-grande-sub">Abrir en Google Maps</span>
              </div>
              <svg class="cta-grande-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
            </a>

            <a href={`https://wa.me/34${whatsapp.replace(/\s/g,'')}`} target="_blank" rel="noopener" class="cta-grande cta-whatsapp">
              <div class="cta-grande-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z" /><path d="M11.999 2C6.477 2 2 6.477 2 12c0 1.89.525 3.659 1.438 5.168L2 22l4.98-1.404A9.954 9.954 0 0 0 12 22c5.523 0 10-4.477 10-10S17.523 2 12 2zm0 18.182a8.162 8.162 0 0 1-4.162-1.14l-.298-.178-3.082.869.878-3.202-.195-.31A8.156 8.156 0 0 1 3.818 12C3.818 7.48 7.48 3.818 12 3.818c4.52 0 8.182 3.662 8.182 8.182 0 4.52-3.662 8.182-8.183 8.182z" /></svg>
              </div>
              <div class="cta-grande-text">
                <span class="cta-grande-label">WhatsApp</span>
                <span class="cta-grande-sub">{whatsapp}</span>
              </div>
              <svg class="cta-grande-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
            </a>

            <a href={`tel:+34${telefono.replace(/\s/g,'')}`} class="cta-grande cta-llamar">
              <div class="cta-grande-icon">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.63 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6 6l.91-.91a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z" /></svg>
              </div>
              <div class="cta-grande-text">
                <span class="cta-grande-label">Llamar ahora</span>
                <span class="cta-grande-sub">{telefono}</span>
              </div>
              <svg class="cta-grande-arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7" /></svg>
            </a>
          </div>
        </div>

        <div class="mapa-wrapper">
          <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2992.0029977817558!2d2.2021733758325714!3d41.41745359413013!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x12a4a34ae1779953%3A0x2de3e3f9610dd008!2sMuebles%20Fran%20Barcelona!5e0!3m2!1ses!2ses!4v1775301481135!5m2!1ses!2ses" allowfullscreen loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== BLOG ===== -->
  <section id="blog">
    <div class="container">
      <div class="blog-header">
        <div>
          <h2 class="section-title" data-sanity={ds(docId, 'paginaInicio', 'blogTitulo')}>{blogTitulo}</h2>
          <p class="section-subtitle" data-sanity={ds(docId, 'paginaInicio', 'blogSubtitulo')}>{blogSubtitulo}</p>
        </div>
      </div>
      <div class="blog-grid">
        {noticias.length === 0 ? (
          <p style="color:#888; grid-column:1/-1; text-align:center; padding:2rem 0;">
            Los artículos del blog aparecerán aquí una vez se publiquen en el panel de contenido.
          </p>
        ) : (
          noticias.map((noticia: any) => (
            <a href={`/novedades/${noticia.slug}`} class="blog-card" style="text-decoration:none;color:inherit;">
              <div class="blog-img">
                {noticia.imagen?.asset?.url ? (
                  <img
                    src={noticia.imagen.asset.url + '?w=600&h=400&fit=crop&auto=format'}
                    alt={noticia.titulo}
                    loading="lazy"
                    style="width:100%;height:100%;object-fit:cover;"
                    data-sanity={ds(noticia._id, 'noticia', 'imagen')}
                  />
                ) : (
                  <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><rect x="3" y="3" width="18" height="18" rx="1"/><path d="M3 9h18M9 21V9"/></svg>
                )}
              </div>
              <div class="blog-info">
                {noticia.fecha && <time class="blog-cat" data-sanity={ds(noticia._id, 'noticia', 'fecha')}>{formatFecha(noticia.fecha)}</time>}
                <h3 data-sanity={ds(noticia._id, 'noticia', 'titulo')}>{noticia.titulo}</h3>
                {noticia.resumen && <p data-sanity={ds(noticia._id, 'noticia', 'resumen')}>{noticia.resumen}</p>}
                <span class="blog-link">Leer más →</span>
              </div>
            </a>
          ))
        )}
      </div>
      {noticias.length > 0 && (
        <div style="text-align:center; margin-top:2.5rem;">
          <a href="/novedades" class="btn-outline-hero" style="display:inline-block;">Ver todos los artículos →</a>
        </div>
      )}
    </div>
  </section>

</Layout>
