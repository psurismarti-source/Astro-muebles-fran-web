---
import Layout from '../layouts/Layout.astro';

// Parámetros pre-rellenados desde otras páginas
const producto = Astro.url.searchParams.get('producto') ?? '';
const pagina = Astro.url.searchParams.get('pagina') ?? '';
---

<Layout
  title="Solicitar Presupuesto | Muebles Fran Barcelona"
  description="Solicita un presupuesto sin compromiso en Muebles Fran Barcelona. Te contactamos en menos de 24 horas."
>

  <div class="page-hero">
    <div class="page-hero-inner">
      <span class="page-hero-tag">Sin compromiso</span>
      <h1>Solicitar Presupuesto</h1>
    </div>
  </div>

  <!-- CONTENIDO DEL FORMULARIO -->
  <!-- TODO: Pega aquí el formulario del presupuesto.html original -->
  <!-- El formulario se mantiene igual que en el HTML original -->
  <section style="max-width:680px; margin: 4rem auto; padding: 0 1.5rem;">
    <p>Rellena el formulario y nos pondremos en contacto contigo en menos de 24 horas laborables.</p>

    <form id="presupuesto-form" style="display:flex; flex-direction:column; gap:1.25rem; margin-top:2rem;">
      <div>
        <label for="nombre">Nombre *</label>
        <input type="text" id="nombre" name="nombre" required />
      </div>
      <div>
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" required />
      </div>
      <div>
        <label for="telefono">Teléfono</label>
        <input type="tel" id="telefono" name="telefono" />
      </div>
      <div>
        <label for="producto">Producto de interés</label>
        <input type="text" id="producto" name="producto" value={producto} />
      </div>
      <div>
        <label for="mensaje">Mensaje *</label>
        <textarea id="mensaje" name="mensaje" rows="5" required></textarea>
      </div>
      <button type="submit" class="gi-cta" style="align-self:flex-start;">Enviar solicitud →</button>
    </form>
  </section>

</Layout>
