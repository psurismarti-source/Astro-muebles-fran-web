# Sanity.io — copia este archivo como .env y rellena los valores
# Los encuentras en sanity.io > tu proyecto > Settings > API

PUBLIC_SANITY_PROJECT_ID=xxxxxxxxxx
PUBLIC_SANITY_DATASET=production

# Token de solo lectura (para el frontend Astro)
PUBLIC_SANITY_API_VERSION=2024-01-01

# Token de escritura (solo necesario si usas mutations desde el frontend, normalmente NO)
# SANITY_API_TOKEN=xxxxxxxxxx
